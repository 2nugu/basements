<?xml version="1.0"?>
<robot name="turtlebot3_burger">

  <link name="base_footprint"/>

  <link name="base_link">
    <inertial>
      <mass value="0.85"/>
      <inertia ixx="0.00259" ixy="0.0" ixz="0.0" iyy="0.00259" iyz="0.0" izz="0.00413"/>
    </inertial>
    <visual>
      <geometry>
        <box size="0.138 0.178 0.192"/>
      </geometry>
      <material name="light_black">
        <color rgba="0.2 0.2 0.2 1.0"/>
      </material>
    </visual>
    <collision>
      <geometry>
        <box size="0.138 0.178 0.192"/>
      </geometry>
    </collision>
  </link>

  <link name="wheel_left_link">
    <inertial>
      <mass value="0.03"/>
      <inertia ixx="0.0000152" ixy="0.0" ixz="0.0" iyy="0.0000152" iyz="0.0" izz="0.0000284"/>
    </inertial>
    <visual>
      <geometry>
        <cylinder radius="0.033" length="0.018"/>
      </geometry>
      <material name="dark">
        <color rgba="0.1 0.1 0.1 1.0"/>
      </material>
    </visual>
    <collision>
      <geometry>
        <cylinder radius="0.033" length="0.018"/>
      </geometry>
    </collision>
  </link>

  <link name="wheel_right_link">
    <inertial>
      <mass value="0.03"/>
      <inertia ixx="0.0000152" ixy="0.0" ixz="0.0" iyy="0.0000152" iyz="0.0" izz="0.0000284"/>
    </inertial>
    <visual>
      <geometry>
        <cylinder radius="0.033" length="0.018"/>
      </geometry>
      <material name="dark">
        <color rgba="0.1 0.1 0.1 1.0"/>
      </material>
    </visual>
    <collision>
      <geometry>
        <cylinder radius="0.033" length="0.018"/>
      </geometry>
    </collision>
  </link>

  <link name="base_scan">
    <inertial>
      <mass value="0.125"/>
      <inertia ixx="0.000106" ixy="0.0" ixz="0.0" iyy="0.000106" iyz="0.0" izz="0.000106"/>
    </inertial>
    <visual>
      <geometry>
        <cylinder radius="0.0508" length="0.055"/>
      </geometry>
      <material name="dark">
        <color rgba="0.1 0.1 0.1 1.0"/>
      </material>
    </visual>
    <collision>
      <geometry>
        <cylinder radius="0.0508" length="0.055"/>
      </geometry>
    </collision>
  </link>

  <joint name="base_joint" type="fixed">
    <parent link="base_footprint"/>
    <child link="base_link"/>
    <origin xyz="0.0 0.0 0.010" rpy="0 0 0"/>
  </joint>

  <joint name="wheel_left_joint" type="continuous">
    <parent link="base_link"/>
    <child link="wheel_left_link"/>
    <origin xyz="0.0 0.08 0.023" rpy="-1.5707963267948966 0 0"/>
    <axis xyz="0 0 1"/>
    <limit effort="1.0" velocity="1.0"/>
  </joint>

  <joint name="wheel_right_joint" type="continuous">
    <parent link="base_link"/>
    <child link="wheel_right_link"/>
    <origin xyz="0.0 -0.08 0.023" rpy="-1.5707963267948966 0 0"/>
    <axis xyz="0 0 1"/>
    <limit effort="1.0" velocity="1.0"/>
  </joint>

  <joint name="scan_joint" type="fixed">
    <parent link="base_link"/>
    <child link="base_scan"/>
    <origin xyz="-0.032 0.0 0.172" rpy="0 0 0"/>
  </joint>

</robot>
